{
  "manifest_version": 3,
  "name": "ScrollShield",
  "version": "1.0.0",
  "description": "Detect doomscrolling on TikTok, Instagram, YouTube and redirect to brain training",
  "permissions": ["storage", "tabs"],
  "options_page": "options.html",
  "host_permissions": [
    "*://*.tiktok.com/*",
    "*://*.instagram.com/*",
    "*://*.youtube.com/*",
    "*://*.youtu.be/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ScrollShield",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tiktok.com/*",
        "*://*.instagram.com/*",
        "*://*.youtube.com/*",
        "*://*.youtu.be/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
